---
// The Presentations library: symbolic decks — the slides behind the talks.
// Mirrors the Articles library, but each card leads to a deck, not a read,
// and carries the deck's robot hero thumbnails as its visual.
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import {
  photoBySlot,
  type PresentationPhoto,
} from "../../data/presentation-photos";
import { presentations } from "../../data/presentations";

const intro = [
  "The slides behind the talks: symbolic decks that anchor a live, spoken narrative — big imagery, few words.",
];

// Card visuals per deck route. Thumbnails are decorative here (the card copy
// already names the robots), so they render with empty alt inside the link.
const heroThumbsByRoute: Record<string, readonly PresentationPhoto[]> = {
  "/presentations/mind-nervous-system-body/": [
    photoBySlot["reachy-mini-hero"],
    photoBySlot["so101-hero"],
  ],
};

const thumbDims = (photo: PresentationPhoto) => {
  const [width, height] = photo.targetDimensions.thumb.split("×").map(Number);
  return { width, height };
};
---

<Layout
  title="Presentations · AgentCulture"
  description="Symbolic slide decks from the AgentCulture mesh — the slides behind the talks."
>
  <PageHero title="Presentations" intro={intro} />

  <section class="section library" aria-label="Presentation library">
    <div class="container">
      <ul class="presentation-grid">
        {
          presentations.map((presentation, i) => {
            const thumbs = heroThumbsByRoute[presentation.route] ?? [];
            return (
              <li data-reveal style={`--reveal-delay: ${Math.min(i * 0.08, 0.32)}s`}>
                <a class="card presentation-card" href={presentation.route}>
                  {thumbs.length > 0 && (
                    <div class="deck-thumbs" aria-hidden="true">
                      {thumbs.map((photo) => {
                        const size = thumbDims(photo);
                        return (
                          <img
                            src={photo.thumbSrc}
                            alt=""
                            width={size.width}
                            height={size.height}
                            loading="lazy"
                            decoding="async"
                            style={`aspect-ratio: ${size.width} / ${size.height}`}
                          />
                        );
                      })}
                    </div>
                  )}
                  <span class="topic">{presentation.topic}</span>
                  <h2>{presentation.title}</h2>
                  <p class="summary muted">{presentation.summary}</p>
                  <div class="source-group">
                    <span class="source-heading">Source projects</span>
                    <ul class="source-projects" aria-label="Source projects">
                      {presentation.sourceProjects.map((project) => (
                        <li>{project}</li>
                      ))}
                    </ul>
                  </div>
                  <span class="go" aria-hidden="true">Open the deck →</span>
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </section>
</Layout>

<style>
  .library {
    padding-top: 0;
  }

  .presentation-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 20rem), 1fr));
    gap: 1.2rem;
  }

  .presentation-card {
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.85rem;
  }

  .deck-thumbs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem;
    width: 100%;
  }

  .deck-thumbs img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0.65rem;
    border: 1px solid var(--line-soft);
  }

  .topic,
  .source-heading {
    font-size: 0.75rem;
    font-weight: 640;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .topic {
    color: var(--accent);
  }

  .presentation-card h2 {
    margin: 0;
    font-size: clamp(1.45rem, 2vw, 1.8rem);
  }

  .summary {
    flex-grow: 1;
    max-width: 48rem;
    line-height: 1.62;
  }

  .source-group {
    display: grid;
    gap: 0.5rem;
  }

  .source-heading {
    color: var(--ink-soft);
  }

  .source-projects {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .source-projects li {
    padding: 0.3rem 0.58rem;
    border: 1px solid var(--line-soft);
    border-radius: 999px;
    color: var(--ink-soft);
    font-size: 0.82rem;
  }

  .go {
    margin-top: 0.4rem;
    color: var(--accent);
    font-weight: 620;
  }
</style>
