---
// The symbolic deck: full-viewport slides the speaker talks over. The data
// layer (mind-nervous-system-body-slides.ts) owns every word on every slide;
// this template only stages them — one hero line per slide, one symbol per
// slide (illustration, glyphs, the architecture diagram, or a photograph),
// and a single spoken cue that stays visually subordinate. The deck says
// less than the article on purpose; the close slide routes depth-seekers to
// the full text.
//
// THE SIX-SLIDE SHAPE (org#23): six visual, declarative slides, each with its
// own dedicated layout branch — no unstyled fallback:
//   1. bridge   — the DeckBridgeIllustration hero beside the declarative pair.
//   2. paths    — three columns, each a DeckPathGlyphs over its label.
//   3. stack    — CliRuntimeStackDiagram embedded exactly once beside the copy.
//   4. surfaces — the reachy-mini-action photo with three labels around it.
//   5. autonomy — a triptych: the so101-action photo + two DeckSituationVignettes.
//   6. close    — two dual-maturity robot cards, the verbatim thesis, sources.
//
// Navigation is progressive enhancement over natural scroll: the dot rail is
// plain anchors, the prev/next chrome and keyboard support exist only under
// html.js, and every reveal/snap runs only behind
// (prefers-reduced-motion: no-preference). The global reduced-motion kill
// switch (global.css) forces animation/transition to none and scroll-behavior
// to auto, so reduced-motion visitors get the finished, still scene and
// instant button/keyboard jumps. With JavaScript disabled the page is a
// complete, plainly scrolling document.
//
// ANIMATION SCOPING (the lobes lesson): every animated element on this page is
// authored inline in this template — the child components (bridge, glyphs,
// vignettes, diagram) each own and scope their own SVG motion. So Astro's
// scoped styles reach every selector here directly; no :global() is needed for
// deck-authored keyframes. :global() is used only where a rule must reach a
// child component's injected markup (the diagram viewport sizing).
import Layout from "../../layouts/Layout.astro";
import {
  mindNervousSystemBodySlides,
  robotLabel,
  deckSources,
  type DeckSlide,
} from "../../data/mind-nervous-system-body-slides";
import { photoBySlot, type PhotoSlotId } from "../../data/presentation-photos";
import { presentations } from "../../data/presentations";
import CliRuntimeStackDiagram from "../../components/CliRuntimeStackDiagram.astro";
import DeckBridgeIllustration from "../../components/deck/DeckBridgeIllustration.astro";
import DeckPathGlyphs from "../../components/deck/DeckPathGlyphs.astro";
import DeckSituationVignettes from "../../components/deck/DeckSituationVignettes.astro";

const card = presentations[0];
const slides: readonly DeckSlide[] = mindNervousSystemBodySlides;

const dims = (spec: string) => {
  const [width, height] = spec.split("×").map(Number);
  return { width, height };
};

/** Resolve a photo slot to the photo record plus its intrinsic pixel size. */
const photoView = (slotId: PhotoSlotId) => {
  const photo = photoBySlot[slotId];
  const { width, height } = dims(photo.targetDimensions.full);
  return { photo, width, height };
};

// Column order fixed by the issue: Coded behavior → coded, Learned policy →
// learned, Agent tools → agent (plan task t5 / component task t3).
const PATH_GLYPHS = ["coded", "learned", "agent"] as const;

// A photo-free autonomy situation maps to one of the two vignette scenes.
const vignetteFor = (label: string): "disconnected" | "routine" =>
  label.toLowerCase().includes("routine") ? "routine" : "disconnected";

const slideViews = slides.map((slide, index) => {
  // The section-level data-robot marker sits on exactly the surfaces slide
  // (its Reachy photo) and the autonomy slide (its SO-101 "Stuck" photo); the
  // close slide leaves it to the two per-robot cards. bridge/paths/stack carry
  // no robot.
  const sectionRobot =
    slide.kind === "surfaces"
      ? slide.robot
      : slide.kind === "autonomy"
        ? slide.situations?.find((situation) => situation.robot)?.robot
        : undefined;
  return { slide, index, sectionRobot, headingId: `${slide.id}-headline` };
});
---

<Layout
  title={`${card.title} · Presentations · AgentCulture`}
  description={card.summary}
>
  <nav class="deck-rail" aria-label="Slides">
    <ol>
      {
        slideViews.map(({ slide, index }) => (
          <li>
            <a
              href={`#${slide.id}`}
              data-deck-dot
              aria-label={`Slide ${index + 1} of ${slides.length}: ${slide.headline}`}
            />
          </li>
        ))
      }
    </ol>
  </nav>

  <article class="deck" aria-label={`${card.title} — slides`}>
    {
      slideViews.map(({ slide, index, sectionRobot, headingId }) => (
        <section
          class:list={["slide", `slide--${slide.kind}`]}
          id={slide.id}
          data-deck-slide={slide.id}
          data-slide-index={index + 1}
          data-kind={slide.kind}
          data-robot={sectionRobot}
          aria-labelledby={headingId}
        >
          {slide.kind === "bridge" && (
            <div class="container slide-grid bridge-grid">
              <div class="slide-copy">
                <a class="back-link" href="/presentations/">
                  ← Presentations
                </a>
                <span class="eyebrow" data-reveal>
                  {slide.eyebrow}
                </span>
                <h1
                  id={headingId}
                  class="hero-headline"
                  data-reveal
                  style="--reveal-delay: 0.08s"
                >
                  {slide.headline}
                </h1>
                <p
                  class="bottom-line bottom-line--lead"
                  data-reveal
                  style="--reveal-delay: 0.2s"
                >
                  {slide.bottomLine}
                </p>
                <p class="spoken" data-reveal style="--reveal-delay: 0.32s">
                  {slide.spokenLine}
                </p>
              </div>
              <div class="slide-visual" data-reveal style="--reveal-delay: 0.16s">
                <DeckBridgeIllustration />
              </div>
            </div>
          )}

          {slide.kind === "paths" && (
            <div class="container stack-flow">
              <div class="slide-head">
                <span class="eyebrow" data-reveal>
                  {slide.eyebrow}
                </span>
                <h2 id={headingId} data-reveal style="--reveal-delay: 0.06s">
                  {slide.headline}
                </h2>
              </div>
              <ol class="paths-grid">
                {slide.columns?.map((column, columnIndex) => (
                  <li
                    class="path-col"
                    data-reveal
                    style={`--reveal-delay: ${0.14 + columnIndex * 0.1}s`}
                  >
                    <span class="path-glyph">
                      <DeckPathGlyphs path={PATH_GLYPHS[columnIndex]} size={92} />
                    </span>
                    <span class="path-label">{column.label}</span>
                  </li>
                ))}
              </ol>
              <p
                class="bottom-line bottom-line--center"
                data-reveal
                style="--reveal-delay: 0.46s"
              >
                {slide.bottomLine}
              </p>
              <p
                class="spoken spoken--center"
                data-reveal
                style="--reveal-delay: 0.54s"
              >
                {slide.spokenLine}
              </p>
            </div>
          )}

          {slide.kind === "stack" && (
            <div class="container slide-grid stack-grid">
              <div class="slide-copy">
                <span class="eyebrow" data-reveal>
                  {slide.eyebrow}
                </span>
                <h2 id={headingId} data-reveal style="--reveal-delay: 0.06s">
                  {slide.headline}
                </h2>
                <p class="bottom-line" data-reveal style="--reveal-delay: 0.18s">
                  {slide.bottomLine}
                </p>
                <p class="spoken" data-reveal style="--reveal-delay: 0.3s">
                  {slide.spokenLine}
                </p>
              </div>
              <div class="slide-diagram" data-reveal style="--reveal-delay: 0.16s">
                <CliRuntimeStackDiagram />
              </div>
            </div>
          )}

          {slide.kind === "surfaces" && slide.photoId && (
            <div class="container stack-flow">
              <div class="slide-head">
                <span class="eyebrow" data-reveal>
                  {slide.eyebrow}
                </span>
                <h2 id={headingId} data-reveal style="--reveal-delay: 0.06s">
                  {slide.headline}
                </h2>
              </div>
              <div class="surfaces-stage" data-reveal style="--reveal-delay: 0.14s">
                {(() => {
                  const pv = photoView(slide.photoId);
                  return (
                    <figure class="surfaces-photo" data-photo-slot={pv.photo.id}>
                      <img
                        src={pv.photo.src}
                        alt={pv.photo.alt}
                        width={pv.width}
                        height={pv.height}
                        loading="lazy"
                        decoding="async"
                      />
                    </figure>
                  );
                })()}
                {slide.labels?.map((label, labelIndex) => (
                  <div
                    class:list={["surface-chip", `chip-${labelIndex + 1}`]}
                    style={`--cd: ${labelIndex * 0.45}s`}
                  >
                    <span class="chip-num" aria-hidden="true">
                      {labelIndex + 1}
                    </span>
                    <span class="chip-label">{label}</span>
                    <span class="chip-node" aria-hidden="true" />
                  </div>
                ))}
              </div>
              <p
                class="bottom-line bottom-line--center"
                data-reveal
                style="--reveal-delay: 0.42s"
              >
                {slide.bottomLine}
              </p>
              <p
                class="spoken spoken--center"
                data-reveal
                style="--reveal-delay: 0.5s"
              >
                {slide.spokenLine}
              </p>
            </div>
          )}

          {slide.kind === "autonomy" && (
            <div class="container stack-flow">
              <div class="slide-head">
                <span class="eyebrow" data-reveal>
                  {slide.eyebrow}
                </span>
                <h2 id={headingId} data-reveal style="--reveal-delay: 0.06s">
                  {slide.headline}
                </h2>
              </div>
              <ul class="autonomy-triptych">
                {slide.situations?.map((situation, situationIndex) => (
                  <li
                    class="autonomy-cell"
                    data-reveal
                    style={`--reveal-delay: ${0.16 + situationIndex * 0.1}s`}
                  >
                    <div class="autonomy-figure">
                      {situation.photoId ? (
                        (() => {
                          const pv = photoView(situation.photoId);
                          return (
                            <figure
                              class="cell-photo"
                              data-photo-slot={pv.photo.id}
                            >
                              <img
                                src={pv.photo.src}
                                alt={pv.photo.alt}
                                width={pv.width}
                                height={pv.height}
                                loading="lazy"
                                decoding="async"
                              />
                            </figure>
                          );
                        })()
                      ) : (
                        <DeckSituationVignettes
                          situation={vignetteFor(situation.label)}
                        />
                      )}
                    </div>
                    <p class="autonomy-caption">
                      <span class="cap-label">{situation.label}</span>
                      <span class="cap-arrow" aria-hidden="true">
                        →
                      </span>
                      <span class="cap-outcome">{situation.outcome}</span>
                    </p>
                  </li>
                ))}
              </ul>
              <p
                class="bottom-line bottom-line--center"
                data-reveal
                style="--reveal-delay: 0.52s"
              >
                {slide.bottomLine}
              </p>
              <p
                class="spoken spoken--center"
                data-reveal
                style="--reveal-delay: 0.6s"
              >
                {slide.spokenLine}
              </p>
            </div>
          )}

          {slide.kind === "close" && (
            <div class="container stack-flow close-flow">
              <div class="slide-head">
                <span class="eyebrow" data-reveal>
                  {slide.eyebrow}
                </span>
                <h2 id={headingId} data-reveal style="--reveal-delay: 0.06s">
                  {slide.headline}
                </h2>
              </div>
              <div class="close-robots">
                {slide.robots?.map((robotEntry, robotIndex) => {
                  const pv = photoView(robotEntry.photoId);
                  const inProgress = robotEntry.status === "in progress";
                  return (
                    <article
                      class="robot-card"
                      data-robot={robotEntry.robot}
                      data-reveal
                      style={`--reveal-delay: ${0.14 + robotIndex * 0.12}s`}
                    >
                      <figure class="card-photo" data-photo-slot={pv.photo.id}>
                        <img
                          src={pv.photo.src}
                          alt={pv.photo.alt}
                          width={pv.width}
                          height={pv.height}
                          loading="lazy"
                          decoding="async"
                        />
                      </figure>
                      <div class="card-body">
                        <div class="card-head">
                          <h3 class="card-name">{robotLabel[robotEntry.robot]}</h3>
                          <span
                            class:list={[
                              "status-badge",
                              inProgress ? "is-progress" : "is-working",
                            ]}
                          >
                            <span class="badge-dot" aria-hidden="true" />
                            {robotEntry.status}
                          </span>
                        </div>
                        <p class="card-traits">{robotEntry.traits}</p>
                        <p class="card-claim">{robotEntry.claim}</p>
                        <code class="card-command">{robotEntry.command}</code>
                      </div>
                    </article>
                  );
                })}
              </div>
              <p class="thesis-final" data-reveal style="--reveal-delay: 0.42s">
                {slide.bottomLine}
              </p>
              <div class="close-foot" data-reveal style="--reveal-delay: 0.52s">
                <div class="close-actions">
                  <a class="cta" href="/articles/mind-nervous-system-body/">
                    The full argument, in text →
                  </a>
                  <a class="cta-quiet" href="/presentations/">
                    All presentations
                  </a>
                </div>
                <details class="sources">
                  <summary>Sources</summary>
                  <ul>
                    {deckSources.projects.map((project) => (
                      <li>
                        <a
                          href={project.repositoryUrl}
                          target="_blank"
                          rel="noreferrer"
                        >
                          <span class="source-label">{project.label}</span>
                          <span class="source-meta">{project.repositoryUrl}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                  <p class="source-note">{deckSources.note}</p>
                </details>
              </div>
            </div>
          )}
        </section>
      ))
    }
  </article>

  <div class="deck-chrome">
    <button type="button" data-deck-prev aria-label="Previous slide" disabled>
      <span aria-hidden="true">↑</span>
    </button>
    <span class="deck-count" data-deck-count aria-hidden="true">
      1 / {slides.length}
    </span>
    <button type="button" data-deck-next aria-label="Next slide">
      <span aria-hidden="true">↓</span>
    </button>
  </div>

  <script is:inline>
    // Deck navigation — progressive enhancement only. Without JavaScript the
    // page is a plain scrolling document: the dot rail is real anchors and
    // the chrome above stays hidden (CSS shows it only under html.js).
    // Motion: scrollIntoView follows the CSS scroll-behavior, and the global
    // reduced-motion kill switch forces that to `auto`, so button and
    // keyboard navigation jump instantly for reduced-motion visitors.
    (function () {
      var slides = Array.prototype.slice.call(
        document.querySelectorAll("[data-deck-slide]")
      );
      if (!slides.length) return;
      var dots = Array.prototype.slice.call(
        document.querySelectorAll("[data-deck-dot]")
      );
      var prev = document.querySelector("[data-deck-prev]");
      var next = document.querySelector("[data-deck-next]");
      var count = document.querySelector("[data-deck-count]");
      var current = 0;

      function update() {
        if (count) count.textContent = current + 1 + " / " + slides.length;
        if (prev) prev.disabled = current === 0;
        if (next) next.disabled = current === slides.length - 1;
        dots.forEach(function (dot, index) {
          if (index === current) dot.setAttribute("aria-current", "true");
          else dot.removeAttribute("aria-current");
        });
      }

      function goTo(index) {
        current = Math.max(0, Math.min(slides.length - 1, index));
        slides[current].scrollIntoView({ block: "start" });
        update();
      }

      if (prev)
        prev.addEventListener("click", function () {
          goTo(current - 1);
        });
      if (next)
        next.addEventListener("click", function () {
          goTo(current + 1);
        });

      // Scroll-spy: whichever slide crosses the middle band of the viewport
      // is current. Band-based, so slides taller than the viewport still
      // register on small screens.
      if ("IntersectionObserver" in window) {
        var spy = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                current = slides.indexOf(entry.target);
                update();
              }
            });
          },
          { rootMargin: "-45% 0px -45% 0px", threshold: 0 }
        );
        slides.forEach(function (slide) {
          spy.observe(slide);
        });
      }

      document.addEventListener("keydown", function (event) {
        if (event.altKey || event.ctrlKey || event.metaKey || event.shiftKey)
          return;
        var target = event.target;
        if (
          target &&
          (target.tagName === "INPUT" ||
            target.tagName === "TEXTAREA" ||
            target.tagName === "SELECT" ||
            target.isContentEditable)
        )
          return;
        switch (event.key) {
          case "ArrowDown":
          case "ArrowRight":
          case "PageDown":
            event.preventDefault();
            goTo(current + 1);
            break;
          case "ArrowUp":
          case "ArrowLeft":
          case "PageUp":
            event.preventDefault();
            goTo(current - 1);
            break;
          case "Home":
            event.preventDefault();
            goTo(0);
            break;
          case "End":
            event.preventDefault();
            goTo(slides.length - 1);
            break;
        }
      });

      update();
    })();
  </script>
</Layout>

<style>
  /* ---------- slides ---------- */

  .slide {
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-block: clamp(3.5rem, 7vh, 5.5rem);
  }

  /* Scroll-snap is a motion opinion: gentle proximity settling, and only for
     visitors who allow motion. Under prefers-reduced-motion: reduce this
     whole block is inert and the deck scrolls as a plain document. */
  @media (prefers-reduced-motion: no-preference) {
    :global(html) {
      scroll-snap-type: y proximity;
    }

    .slide {
      scroll-snap-align: start;
    }

    .slide:first-child {
      /* the opening slide sits directly under the header — snapping it
         would tug the header out of view at the top of the page */
      scroll-snap-align: none;
    }
  }

  /* two-column layouts (bridge, stack): copy beside a visual */
  .slide-grid {
    display: grid;
    gap: clamp(1.8rem, 4.5vw, 3.6rem);
    align-items: center;
  }

  /* stacked layouts (paths, surfaces, autonomy, close): head, symbol, anchor */
  .stack-flow {
    display: grid;
    gap: clamp(1.4rem, 3.6vw, 2.6rem);
    width: min(100% - 3rem, 68rem);
  }

  @media (min-width: 60rem) {
    .bridge-grid,
    .stack-grid {
      grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    }
  }

  .slide-copy {
    display: grid;
    gap: 0;
    align-content: center;
  }

  .slide-head {
    display: grid;
    gap: 0.35rem;
    justify-items: center;
    text-align: center;
    max-width: 44rem;
    margin-inline: auto;
  }

  .slide-head .eyebrow,
  .slide-copy .eyebrow {
    margin-bottom: 0;
  }

  /* ---------- type: the deck is the site at its most cinematic ---------- */

  .hero-headline {
    font-size: clamp(2.4rem, 6vw, 4.7rem);
    line-height: 1.04;
    margin: 0.5rem 0 0.35em;
  }

  .slide h2 {
    font-size: clamp(1.95rem, 4.2vw, 3.15rem);
    line-height: 1.08;
    margin: 0 0 0.1em;
  }

  /* the declarative anchor line beneath each slide's symbol */
  .bottom-line {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2.25rem);
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
    margin: 0.6rem 0 0;
    max-width: 34rem;
  }

  .bottom-line--lead {
    font-size: clamp(1.6rem, 3.7vw, 2.7rem);
    color: var(--accent-strong);
  }

  .bottom-line--center {
    text-align: center;
    max-width: 30rem;
    margin-inline: auto;
  }

  .spoken {
    font-size: clamp(1.05rem, 1.7vw, 1.3rem);
    line-height: 1.6;
    font-weight: 420;
    color: var(--ink-soft);
    max-width: 38rem;
    margin: 1.2rem 0 0;
  }

  .spoken--center {
    text-align: center;
    margin-inline: auto;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    color: var(--ink-soft);
    text-decoration: none;
    font-size: 0.92rem;
  }

  .back-link:hover {
    color: var(--accent);
  }

  /* ---------- slide 1: the bridge ---------- */

  .slide-visual {
    min-width: 0;
  }

  /* ---------- slide 2: intelligence paths ---------- */

  .paths-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: clamp(1.4rem, 4vw, 2.8rem);
    grid-template-columns: 1fr;
    justify-items: center;
  }

  @media (min-width: 46rem) {
    .paths-grid {
      grid-template-columns: repeat(3, 1fr);
      align-items: start;
    }
  }

  .path-col {
    display: grid;
    justify-items: center;
    gap: 1.1rem;
    text-align: center;
  }

  .path-glyph {
    display: grid;
    place-items: center;
    width: clamp(6rem, 13vw, 8.5rem);
    height: clamp(6rem, 13vw, 8.5rem);
    border-radius: 50%;
    background: color-mix(in srgb, var(--accent) 7%, var(--surface));
    border: 1px solid var(--line-soft);
    box-shadow: var(--shadow);
  }

  .path-label {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 2.1vw, 1.55rem);
    font-weight: 560;
    color: var(--ink);
  }

  /* ---------- slide 3: the architecture diagram ---------- */

  .slide-diagram {
    max-height: min(72vh, 46rem);
    overflow-y: auto;
    overflow-x: hidden;
  }

  .slide-diagram :global(.cli-runtime-diagram) {
    margin: 0 auto;
  }

  .slide-diagram :global(.diagram-viewport svg) {
    min-width: 26rem;
  }

  /* ---------- slide 4: runtime surfaces around the photo ---------- */

  .surfaces-stage {
    display: grid;
    gap: clamp(0.9rem, 2.4vw, 1.6rem);
    grid-template-columns: 1fr;
    grid-template-areas:
      "top"
      "photo"
      "left"
      "right";
    justify-items: center;
    align-items: center;
    max-width: 26rem;
    margin-inline: auto;
    width: 100%;
  }

  @media (min-width: 54rem) {
    .surfaces-stage {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.7fr) minmax(0, 1fr);
      grid-template-rows: auto auto auto;
      grid-template-areas:
        ".    top    ."
        "left photo  right"
        ".    .      .";
      column-gap: clamp(1rem, 3vw, 2.4rem);
      max-width: 58rem;
    }
  }

  .surfaces-photo {
    grid-area: photo;
    margin: 0;
    width: 100%;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--line-soft);
    box-shadow: var(--shadow-lift);
  }

  .surfaces-photo img {
    display: block;
    width: 100%;
    height: auto;
  }

  .chip-1 {
    grid-area: top;
  }
  .chip-2 {
    grid-area: left;
  }
  .chip-3 {
    grid-area: right;
  }

  .surface-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 1rem 0.6rem 0.6rem;
