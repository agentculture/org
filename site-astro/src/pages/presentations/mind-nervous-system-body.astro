---
// The symbolic deck: full-viewport slides the speaker talks over. The data
// layer (mind-nervous-system-body-slides.ts) owns every word on every slide;
// this template only stages them — big type, one photograph per robot slide,
// a single spoken line, never a paragraph block. The deck says less than the
// article on purpose; the close slide routes depth-seekers to the full text.
//
// THE REFRAME (org#21): the deck leads with the operational architecture — a
// CLI for intelligence, a runtime for embodiment — rather than the mind/
// nervous-system/body metaphor. Ten slides, eight kinds: opener, thesis,
// diagram (embeds CliRuntimeStackDiagram), contrast (the CLI-vs-runtime
// table), robot (photo slides), commands (photo + an ordered command block),
// rules (a verbatim rules.toml excerpt), and close (actions + deckSources).
//
// Navigation is progressive enhancement over natural scroll: the dot rail is
// plain anchors, the prev/next chrome and keyboard support exist only under
// html.js, and every snap/reveal runs only behind
// (prefers-reduced-motion: no-preference). With JavaScript disabled the page
// is a complete, plainly scrolling document.
import Layout from "../../layouts/Layout.astro";
import {
  mindNervousSystemBodySlides,
  deckSources,
  type DeckSlide,
} from "../../data/mind-nervous-system-body-slides";
import { photoBySlot } from "../../data/presentation-photos";
import { presentations } from "../../data/presentations";
import CliRuntimeStackDiagram from "../../components/CliRuntimeStackDiagram.astro";

const card = presentations[0];
const slides: readonly DeckSlide[] = mindNervousSystemBodySlides;

const dims = (spec: string) => {
  const [width, height] = spec.split("×").map(Number);
  return { width, height };
};

const slideViews = slides.map((slide, index) => {
  const photo = slide.photoId ? photoBySlot[slide.photoId] : undefined;
  const size = photo ? dims(photo.targetDimensions.full) : undefined;
  return {
    slide,
    index,
    photo,
    size,
    flipped: photo?.role === "action",
    headingId: `${slide.id}-headline`,
  };
});

// The thesis headline is one verbatim string of two sentences — the stage
// splits it into two reveal lines so each sentence lands on its own beat.
// The split is presentational only: joined back together the text is
// byte-identical to the source string.
const thesisLines = (headline: string) => headline.split(/(?<=\.)\s+/);
---

<Layout
  title={`${card.title} · Presentations · AgentCulture`}
  description={card.summary}
>
  <nav class="deck-rail" aria-label="Slides">
    <ol>
      {
        slideViews.map(({ slide, index }) => (
          <li>
            <a
              href={`#${slide.id}`}
              data-deck-dot
              aria-label={`Slide ${index + 1} of ${slides.length}: ${slide.headline}`}
            />
          </li>
        ))
      }
    </ol>
  </nav>

  <article class="deck" aria-label={`${card.title} — slides`}>
    {
      slideViews.map(({ slide, index, photo, size, flipped, headingId }) => (
        <section
          class:list={["slide", `slide--${slide.kind}`, flipped && "is-flipped"]}
          id={slide.id}
          data-deck-slide={slide.id}
          data-slide-index={index + 1}
          data-kind={slide.kind}
          data-robot={slide.robot}
          aria-labelledby={headingId}
        >
          <div class="container slide-grid">
            <div class="slide-copy">
              {slide.kind === "opener" && (
                <a class="back-link" href="/presentations/">
                  ← Presentations
                </a>
              )}
              <span class="eyebrow" data-reveal>
                {slide.eyebrow}
              </span>
              {slide.kind === "opener" ? (
                <h1 id={headingId} data-reveal style="--reveal-delay: 0.08s">
                  {slide.headline}
                </h1>
              ) : slide.kind === "thesis" ? (
                <h2 id={headingId} class="thesis-headline">
                  {thesisLines(slide.headline).map((line, lineIndex) => (
                    <span
                      class:list={["thesis-line", lineIndex === 0 && "is-lead"]}
                      data-reveal
                      style={`--reveal-delay: ${0.1 + lineIndex * 0.18}s`}
                    >
                      {line}
                    </span>
                  ))}
                </h2>
              ) : (
                <h2 id={headingId} data-reveal style="--reveal-delay: 0.08s">
                  {slide.headline}
                </h2>
              )}
              <p class="spoken" data-reveal style="--reveal-delay: 0.22s">
                {slide.spokenLine}
              </p>

              {slide.kind === "opener" && slides[1] && (
                <a
                  class="begin"
                  href={`#${slides[1].id}`}
                  data-reveal
                  style="--reveal-delay: 0.36s"
                >
                  Begin <span aria-hidden="true">↓</span>
                </a>
              )}

              {slide.kind === "contrast" && slide.contrastRows && (
                <div class="contrast-table" data-reveal style="--reveal-delay: 0.3s">
                  <table>
                    <thead>
                      <tr>
                        <th scope="col">Dimension</th>
                        <th scope="col">CLI</th>
                        <th scope="col">Runtime</th>
                      </tr>
                    </thead>
                    <tbody>
                      {slide.contrastRows.map((row) => (
                        <tr>
                          <th scope="row">{row.dimension}</th>
                          <td>{row.cli}</td>
                          <td>{row.runtime}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}

              {slide.kind === "commands" && slide.commandLines && (
                <pre class="command-block" data-reveal style="--reveal-delay: 0.3s">{slide.commandLines.map((line) => <code>{line}</code>)}</pre>
              )}

              {slide.kind === "rules" && slide.rulesToml && (
                <pre class="rules-block" data-reveal style="--reveal-delay: 0.3s"><code>{
                  slide.rulesToml
                }</code></pre>
              )}

              {slide.kind === "close" && (
                <div class="close-actions" data-reveal style="--reveal-delay: 0.3s">
                  <a class="cta" href="/articles/mind-nervous-system-body/">
                    The full argument, in text →
                  </a>
                  <a class="cta-quiet" href="/presentations/">
                    All presentations
                  </a>
                </div>
              )}
              {slide.kind === "close" && (
                <details class="sources" data-reveal style="--reveal-delay: 0.4s">
                  <summary>Sources</summary>
                  <ul>
                    {deckSources.projects.map((project) => (
                      <li>
                        <a href={project.repositoryUrl} target="_blank" rel="noreferrer">
                          <span class="source-label">{project.label}</span>
                          <span class="source-meta">{project.repositoryUrl}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                  <p class="source-note">{deckSources.note}</p>
                </details>
              )}
            </div>

            {slide.kind === "diagram" && (
              <div class="slide-diagram" data-reveal style="--reveal-delay: 0.16s">
                <CliRuntimeStackDiagram />
              </div>
            )}

            {photo && size && (
              <figure
                class="slide-photo"
                data-photo-slot={photo.id}
                data-reveal
                style="--reveal-delay: 0.16s"
              >
                <img
                  src={photo.src}
                  alt={photo.alt}
                  width={size.width}
                  height={size.height}
                  loading="lazy"
                  decoding="async"
                  style={`aspect-ratio: ${size.width} / ${size.height}`}
                />
              </figure>
            )}
          </div>
        </section>
      ))
    }
  </article>

  <div class="deck-chrome">
    <button type="button" data-deck-prev aria-label="Previous slide" disabled>
      <span aria-hidden="true">↑</span>
    </button>
    <span class="deck-count" data-deck-count aria-hidden="true">
      1 / {slides.length}
    </span>
    <button type="button" data-deck-next aria-label="Next slide">
      <span aria-hidden="true">↓</span>
    </button>
  </div>

  <script is:inline>
    // Deck navigation — progressive enhancement only. Without JavaScript the
    // page is a plain scrolling document: the dot rail is real anchors and
    // the chrome above stays hidden (CSS shows it only under html.js).
    // Motion: scrollIntoView follows the CSS scroll-behavior, and the global
    // reduced-motion kill switch forces that to `auto`, so button and
    // keyboard navigation jump instantly for reduced-motion visitors.
    (function () {
      var slides = Array.prototype.slice.call(
        document.querySelectorAll("[data-deck-slide]")
      );
      if (!slides.length) return;
      var dots = Array.prototype.slice.call(
        document.querySelectorAll("[data-deck-dot]")
      );
      var prev = document.querySelector("[data-deck-prev]");
      var next = document.querySelector("[data-deck-next]");
      var count = document.querySelector("[data-deck-count]");
      var current = 0;

      function update() {
        if (count) count.textContent = current + 1 + " / " + slides.length;
        if (prev) prev.disabled = current === 0;
        if (next) next.disabled = current === slides.length - 1;
        dots.forEach(function (dot, index) {
          if (index === current) dot.setAttribute("aria-current", "true");
          else dot.removeAttribute("aria-current");
        });
      }

      function goTo(index) {
        current = Math.max(0, Math.min(slides.length - 1, index));
        slides[current].scrollIntoView({ block: "start" });
        update();
      }

      if (prev)
        prev.addEventListener("click", function () {
          goTo(current - 1);
        });
      if (next)
        next.addEventListener("click", function () {
          goTo(current + 1);
        });

      // Scroll-spy: whichever slide crosses the middle band of the viewport
      // is current. Band-based, so slides taller than the viewport still
      // register on small screens.
      if ("IntersectionObserver" in window) {
        var spy = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                current = slides.indexOf(entry.target);
                update();
              }
            });
          },
          { rootMargin: "-45% 0px -45% 0px", threshold: 0 }
        );
        slides.forEach(function (slide) {
          spy.observe(slide);
        });
      }

      document.addEventListener("keydown", function (event) {
        if (event.altKey || event.ctrlKey || event.metaKey || event.shiftKey)
          return;
        var target = event.target;
        if (
          target &&
          (target.tagName === "INPUT" ||
            target.tagName === "TEXTAREA" ||
            target.tagName === "SELECT" ||
            target.isContentEditable)
        )
          return;
        switch (event.key) {
          case "ArrowDown":
          case "ArrowRight":
          case "PageDown":
            event.preventDefault();
            goTo(current + 1);
            break;
          case "ArrowUp":
          case "ArrowLeft":
          case "PageUp":
            event.preventDefault();
            goTo(current - 1);
            break;
          case "Home":
            event.preventDefault();
            goTo(0);
            break;
          case "End":
            event.preventDefault();
            goTo(slides.length - 1);
            break;
        }
      });

      update();
    })();
  </script>
</Layout>

<style>
  /* ---------- slides ---------- */

  .slide {
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-block: clamp(3.5rem, 7vh, 5.5rem);
  }

  /* Scroll-snap is a motion opinion: gentle proximity settling, and only for
     visitors who allow motion. Under prefers-reduced-motion: reduce this
     whole block is inert and the deck scrolls as a plain document. */
  @media (prefers-reduced-motion: no-preference) {
    :global(html) {
      scroll-snap-type: y proximity;
    }

    .slide {
      scroll-snap-align: start;
    }

    .slide:first-child {
      /* the opening slide sits directly under the header — snapping it
         would tug the header out of view at the top of the page */
      scroll-snap-align: none;
    }
  }

  .slide-grid {
    display: grid;
    gap: clamp(1.8rem, 4.5vw, 3.6rem);
    align-items: center;
  }

  @media (min-width: 60rem) {
    .slide--robot .slide-grid,
    .slide--commands .slide-grid {
      grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    }

    .slide--robot.is-flipped .slide-grid,
    .slide--commands.is-flipped .slide-grid {
      grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    }

    .slide--robot.is-flipped .slide-copy,
    .slide--commands.is-flipped .slide-copy {
      order: 2;
    }

    .slide--diagram .slide-grid {
      grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    }
  }

  /* ---------- type: the deck is the site at its most cinematic ---------- */

  .slide--opener h1 {
    font-size: clamp(2.5rem, 6.4vw, 4.9rem);
    margin-bottom: 0.45em;
  }

  .thesis-headline {
    display: grid;
    gap: 0.15em;
    font-size: clamp(2.3rem, 5.6vw, 4.3rem);
    margin-bottom: 0.5em;
  }

  .thesis-line {
    display: block;
  }

  /* the first sentence — the CLI, the mind's interface — is the accent
     layer; the second — the runtime, embodiment — stays ink so the deck's
     two halves read as distinct claims. */
  .thesis-line.is-lead {
    color: var(--accent);
  }

  .slide h2 {
    font-size: clamp(2.1rem, 4.4vw, 3.3rem);
    margin-bottom: 0.45em;
  }

  .spoken {
    font-size: clamp(1.12rem, 1.9vw, 1.42rem);
    line-height: 1.62;
    font-weight: 420;
    color: var(--ink-soft);
    max-width: 38rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2.4rem;
    color: var(--ink-soft);
    text-decoration: none;
    font-size: 0.92rem;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .begin {
    display: inline-block;
    margin-top: 2.4rem;
    padding: 0.65rem 1.35rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--ink);
    text-decoration: none;
    font-weight: 550;
  }

  .begin:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ---------- the diagram slide ---------- */

  .slide-diagram {
    max-height: min(72vh, 46rem);
    overflow-y: auto;
    overflow-x: hidden;
  }

  .slide-diagram :global(.cli-runtime-diagram) {
    margin: 0 auto;
  }

  .slide-diagram :global(.diagram-viewport svg) {
    min-width: 26rem;
  }

  /* ---------- the contrast table ---------- */

  .contrast-table {
    margin-top: 1.6rem;
    max-width: 42rem;
    overflow-x: auto;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius);
  }

  .contrast-table table {
    width: 100%;
    border-collapse: collapse;
    font-size: clamp(0.92rem, 1.3vw, 1.08rem);
  }

  .contrast-table th,
  .contrast-table td {
    padding: 0.65rem 0.9rem;
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid var(--line-soft);
  }

  .contrast-table thead th {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .contrast-table tbody th {
    font-weight: 560;
    white-space: nowrap;
  }

  .contrast-table tbody tr:last-child th,
  .contrast-table tbody tr:last-child td {
    border-bottom: none;
  }

  /* ---------- command + rules code blocks ---------- */

  .command-block,
  .rules-block {
    margin-top: 1.6rem;
    max-width: 34rem;
    padding: 1.1rem 1.3rem;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--surface) 88%, transparent);
    font-family: var(--font-mono);
    font-size: clamp(0.88rem, 1.35vw, 1.08rem);
    line-height: 1.75;
    color: var(--ink);
    overflow-x: auto;
    /* A projected audience can't scroll: long invocations wrap with a hanging
       indent instead of clipping past the block's edge. */
    white-space: pre-wrap;
  }

  .command-block code {
    display: block;
    padding-left: 2ch;
    text-indent: -2ch;
  }

  /* ---------- the photograph ---------- */

  .slide-photo {
    margin: 0;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--line-soft);
    box-shadow: var(--shadow-lift);
  }

  .slide-photo img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ---------- the close ---------- */

  .slide--close {
    /* room for the fixed chrome under the actions on short viewports */
    padding-bottom: 7rem;
  }

  .close-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.5rem;
    margin-top: 2.2rem;
  }

  .cta {
    display: inline-block;
    padding: 0.78rem 1.5rem;
    border-radius: 999px;
    background: var(--accent-strong);
    color: var(--on-accent);
    text-decoration: none;
    font-weight: 600;
  }

  .cta:hover {
    box-shadow: var(--shadow-lift);
  }

  .cta-quiet {
    color: var(--ink-soft);
  }

  .cta-quiet:hover {
    color: var(--accent);
  }

  .sources {
    margin-top: 2.8rem;
    max-width: 44rem;
    font-size: 0.86rem;
  }

  .sources summary {
    cursor: pointer;
    color: var(--ink-soft);
    font-size: 0.78rem;
    font-weight: 640;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .sources ul {
    list-style: none;
    margin-top: 1.1rem;
    display: grid;
    gap: 0.75rem;
  }

  @media (min-width: 48rem) {
    .sources ul {
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem 2rem;
    }
  }

  .sources a {
    display: grid;
    gap: 0.1rem;
    text-decoration: none;
    color: var(--ink);
  }

  .sources a:hover .source-label {
    color: var(--accent);
  }

  .source-label {
    font-weight: 550;
  }

  .source-meta {
    color: var(--ink-soft);
    font-size: 0.8rem;
    word-break: break-word;
  }

  .source-note {
    margin-top: 1.2rem;
    color: var(--ink-soft);
  }

  /* ---------- the rail: slides as nodes on a thread ---------- */

  .deck-rail {
    position: fixed;
    top: 50%;
    right: clamp(0.4rem, 1.4vw, 1.3rem);
    transform: translateY(-50%);
    z-index: 40;
  }

  .deck-rail ol {
    position: relative;
    list-style: none;
    display: grid;
    gap: 0.35rem;
    justify-items: center;
  }

  .deck-rail ol::before {
    content: "";
    position: absolute;
    inset: 0.5rem auto 0.5rem 50%;
    width: 1px;
    transform: translateX(-50%);
    background: var(--mesh-thread);
  }

  .deck-rail a {
    position: relative;
    display: grid;
    place-items: center;
    width: 1.05rem;
    height: 1.05rem;
  }

  .deck-rail a::before {
    content: "";
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--bg);
    border: 1px solid var(--mesh-thread);
  }

  .deck-rail a:hover::before {
    border-color: var(--accent);
  }

  .deck-rail a[aria-current="true"]::before {
    background: var(--accent);
    border-color: var(--accent);
  }

  @media (max-width: 40rem) {
    .deck-rail {
      display: none;
    }
  }

  /* ---------- the chrome: js-only, hidden for everyone else ---------- */

  .deck-chrome {
    position: fixed;
    right: clamp(0.8rem, 2vw, 1.6rem);
    bottom: clamp(0.8rem, 2vw, 1.6rem);
    z-index: 40;
    display: none;
    align-items: center;
    gap: 0.55rem;
    padding: 0.45rem 0.7rem;
    background: color-mix(in srgb, var(--surface) 88%, transparent);
    backdrop-filter: blur(6px);
    border: 1px solid var(--line-soft);
    border-radius: 999px;
    box-shadow: var(--shadow);
  }

  :global(html.js) .deck-chrome {
    display: inline-flex;
  }

  .deck-chrome button {
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--ink);
    font: inherit;
    cursor: pointer;
    display: grid;
    place-items: center;
  }

  .deck-chrome button:hover:not(:disabled) {
    border-color: var(--accent);
    color: var(--accent);
  }

  .deck-chrome button:disabled {
    opacity: 0.35;
    cursor: default;
  }

  .deck-count {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink-soft);
    min-width: 3.4em;
    text-align: center;
  }
</style>
