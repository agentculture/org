---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import site from "../data/site";

const { engage, hero } = site;
---

<Layout
  title={`Engage · ${hero.title}`}
  description={engage.intro[0] ?? hero.tagline}
>
  <PageHero title="Engage" intro={engage.intro} />

  <section class="section" aria-label="Channels">
    <div class="container">
      <ul class="channels">
        {
          engage.channels.map((channel, i) => (
            <li data-reveal style={`--reveal-delay: ${Math.min(i * 0.1, 0.3)}s`}>
              <a class="card channel" href={channel.url}>
                <span class="glyph" aria-hidden="true">
                  <svg width="34" height="34" viewBox="0 0 40 40" fill="none">
                    <circle cx="20" cy="23" r="3.2" fill="currentColor" />
                    <path
                      d="M12 16 a11 11 0 0 1 16 0"
                      stroke="currentColor"
                      stroke-width="1.6"
                      stroke-linecap="round"
                    />
                    <path
                      d="M8 11 a17 17 0 0 1 24 0"
                      stroke="currentColor"
                      stroke-width="1.6"
                      stroke-linecap="round"
                      opacity="0.5"
                    />
                  </svg>
                </span>
                <span class="body">
                  <h2>{channel.title}</h2>
                  <p class="muted">{channel.description}</p>
                  <span class="cta">
                    {channel.cta}
                    <span class="arrow" aria-hidden="true">→</span>
                  </span>
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</Layout>

<style>
  .section {
    padding-top: 1rem;
  }

  .channels {
    list-style: none;
    max-width: 46rem;
    display: grid;
    gap: 1.3rem;
  }

  .channel {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    padding: 1.8rem 2rem;
  }

  .channel .glyph {
    flex-shrink: 0;
    color: var(--accent);
    margin-top: 0.2rem;
  }

  .channel h2 {
    font-size: 1.35rem;
    margin-bottom: 0.3em;
  }

  .channel p {
    font-size: 0.98rem;
    margin-bottom: 0.9em;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--accent);
    font-weight: 560;
    font-size: 0.95rem;
  }

  @media (prefers-reduced-motion: no-preference) {
    .cta .arrow {
      transition: transform 0.35s var(--ease-out);
    }

    .channel:hover .arrow {
      transform: translateX(5px);
    }
  }

  @media (max-width: 34rem) {
    .channel {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
