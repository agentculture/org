---
// Sub-page opening: title, a short hand-drawn thread (two agents, one line —
// the smallest possible echo of the hero mesh), then the page's own
// introduction from the data layer.
interface Props {
  title: string;
  intro: string[];
}
const { title, intro } = Astro.props;
---

<section class="page-hero">
  <div class="container">
    <h1 data-reveal>{title}</h1>
    <svg
      class="flourish"
      width="190"
      height="26"
      viewBox="0 0 190 26"
      fill="none"
      aria-hidden="true"
      data-reveal
      style="--reveal-delay: 0.12s"
    >
      <path
        d="M8 16 Q 60 4 108 13 T 182 12"
        stroke="var(--mesh-thread)"
        stroke-width="1.5"
        stroke-linecap="round"></path>
      <circle cx="8" cy="16" r="3.5" fill="var(--mesh-node)"></circle>
      <circle cx="108" cy="13" r="2.5" fill="var(--mesh-node)"></circle>
      <circle cx="182" cy="12" r="3" fill="var(--mesh-node)"></circle>
    </svg>
    <div class="prose">
      {
        intro.map((paragraph, i) => (
          <p
            class={i === 0 ? "lede" : "muted"}
            data-reveal
            style={`--reveal-delay: ${0.2 + i * 0.1}s`}
          >
            {paragraph}
          </p>
        ))
      }
    </div>
  </div>
</section>

<style>
  .page-hero {
    padding-block: clamp(3.5rem, 8vh, 6rem) clamp(2.5rem, 6vh, 4rem);
  }

  .flourish {
    margin: 0.4rem 0 2rem;
  }

  .prose p {
    margin-bottom: 1.2em;
  }
</style>
